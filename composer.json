{
    "name": "nano/dto-json-entity-field-bundle",
    "description": "Symfony bundle providing a generic Doctrine dto_json field backed by tagged immutable DTO services.",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13 || ^3.0",
        "doctrine/orm": "^3.3",
        "symfony/config": "^7.3 || ^8.0",
        "symfony/dependency-injection": "^7.3 || ^8.0",
        "symfony/framework-bundle": "^7.3 || ^8.0",
        "symfony/http-kernel": "^7.3 || ^8.0",
        "symfony/property-access": "^7.3 || ^8.0",
        "symfony/property-info": "^7.3 || ^8.0",
        "symfony/serializer": "^7.3 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/cache": "^7.3 || ^8.0",
        "symfony/yaml": "^7.3 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nano\\DtoJsonEntityFieldBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nano\\DtoJsonEntityFieldBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "Nano\\DtoJsonEntityFieldBundle\\NanoDtoJsonEntityFieldBundle"
        }
    },
    "config": {
        "sort-packages": true
    }
}
